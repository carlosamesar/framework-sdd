# Cargar primero rag/.env; si no existe, se usa la raíz del framework (../.env).
#
# --- Opción A: Postgres local con Docker (recomendado si la nube da ETIMEDOUT) ---
# 1) Desde la raíz del framework:
#    npm run rag:db:up
# 2) En rag/.env (Node se conecta al puerto publicado, NO uses 5432 si mapeas 5433):
# RAG_DB_HOST=127.0.0.1
# RAG_DB_PORT=5433
# RAG_DB_NAME=framework_rag
# RAG_DB_USER=rag
# RAG_DB_PASSWORD=rag_local_dev
# RAG_DB_SSL=false
# 3) npm run rag:migrate && npm run rag:index
#
# --- Opción B: Misma BD remota que el monorepo (../.env con DB_*) ---
# Misma BD que el resto del monorepo (o dedicada)
RAG_DB_HOST=
RAG_DB_PORT=5432
RAG_DB_NAME=
RAG_DB_USER=
RAG_DB_PASSWORD=
# true | false (DigitalOcean suele requerir SSL; local Docker = false)
RAG_DB_SSL=true

# Backend de embeddings: ollama (local) | openai
RAG_EMBEDDING_BACKEND=ollama
# Dimensión del vector (debe coincidir con el modelo)
RAG_EMBEDDING_DIM=768
# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
RAG_EMBED_MODEL=nomic-embed-text
# OpenAI (solo si RAG_EMBEDDING_BACKEND=openai)
# OPENAI_API_KEY=
# RAG_EMBEDDING_DIM=1536
# RAG_OPENAI_MODEL=text-embedding-3-small

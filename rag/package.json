{
  "name": "framework-sdd-rag",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "RAG con pgvector sobre docs del framework (AGENTS, OpenSpec, registry)",
  "scripts": {
    "migrate": "node scripts/run-migration.mjs",
    "index": "node scripts/index.mjs",
    "query": "node scripts/query.mjs",
    "test": "FRAMEWORK_SDD_AGENTIC_MODE=skip node scripts/test-functional.mjs",
    "test:strict": "FRAMEWORK_SDD_REQUIRE_AGENTIC=1 FRAMEWORK_SDD_AGENTIC_MODE=resilience node scripts/test-functional.mjs",
    "test:agentic-live": "FRAMEWORK_SDD_REQUIRE_AGENTIC=1 FRAMEWORK_SDD_AGENTIC_MODE=live node scripts/test-functional.mjs",
    "test:agentic-live:continuous": "FRAMEWORK_SDD_REQUIRE_AGENTIC=1 FRAMEWORK_SDD_AGENTIC_MODE=live FRAMEWORK_SDD_AGENTIC_LIVE_ATTEMPTS=3 FRAMEWORK_SDD_AGENTIC_LIVE_BACKOFF_MS=2000 node scripts/test-functional.mjs",
    "evidence:init": "node scripts/init-db.mjs",
    "evidence:init-reset": "node scripts/init-db.mjs --reset --check",
    "evidence:init-check": "node scripts/init-db.mjs --check",
    "evidence:capture": "node scripts/capture-evidence.mjs",
    "evidence:search": "node scripts/search.mjs",
    "evidence:vectorize": "node scripts/vectorize.mjs",
    "evidence:notify:slack": "node scripts/notify-slack.mjs",
    "evidence:export": "node scripts/audit-export.mjs",
    "evidence:score": "node scripts/maturity-score.mjs",
    "evidence:score:all": "node scripts/maturity-score.mjs --all",
    "evidence:certify": "node scripts/maturity-score.mjs --threshold=95",
    "evidence:pipeline": "node scripts/run-pipeline.mjs",
    "evidence:slack:commands": "node scripts/slack-command-server.mjs",
    "sdd:new": "node scripts/sdd-new.mjs",
    "sdd:activate": "node scripts/activate-change.mjs",
    "sdd:run": "node scripts/run-langgraph-real.mjs",
    "sdd:run:raw": "node langgraph/run.mjs",
    "sdd:run:real": "node scripts/run-langgraph-real.mjs",
    "sdd:run:real:continuous": "node scripts/run-langgraph-real.mjs --continuous-live --live-attempts=3 --live-backoff-ms=2000",
    "sdd:run:real:json": "node scripts/run-langgraph-real.mjs --json",
    "sdd:cycle": "node scripts/sdd-cycle.mjs",
    "sdd:cycle:no-agents": "node scripts/sdd-cycle.mjs --agents=false",
    "sdd:cycle:strict": "node scripts/sdd-cycle.mjs --json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.1.2",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  }
}

# Copiar a ~/.config/framework-sdd/engram-daemon.env y chmod 600.
# NUNCA commitear el archivo real (contiene secretos).
#
# ENGRAM_GIT_TOKEN=<github_pat_fine_grained_o_classic>
# Opcional si el remote ya está configurado con SSH/credential helper:
# ENGRAM_GIT_TOKEN=

# Ruta al clon de engineering-knowledge-base (donde está engram.db)
# ENGRAM_DATA_DIR=/ruta/absoluta/Framework-SDD/engineering-knowledge-base

# Remote HTTPS (por defecto el repo público del knowledge base)
# ENGRAM_GIT_REMOTE=https://github.com/carlosamesar/engineering-knowledge-base.git

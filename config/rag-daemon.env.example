# Copiar a ~/.config/framework-sdd/rag-daemon.env (chmod 600) o usar config/rag-daemon.local.env (gitignored).
#
# Intervalo entre reindexados completos (segundos). Default en script: 3600 (1 h).
# RAG_INDEX_INTERVAL=3600
#
# Variables de BD: el indexer lee ../.env del framework (DB_* o RAG_DB_*).
# Si systemd no hereda ese archivo, duplica aquí las mismas variables:
# DB_HOST=
# DB_PORT=25060
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# RAG_DB_SSL=true
#
# Embeddings (Ollama recomendado):
# RAG_EMBEDDING_BACKEND=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# RAG_EMBED_MODEL=nomic-embed-text
# RAG_EMBEDDING_DIM=768

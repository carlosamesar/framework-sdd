{
  "name": "framework-sdd",
  "version": "2.1.0",
  "private": true,
  "description": "Specification-Driven Development — validación OpenSpec y artefactos de verificación para agentes",
  "type": "module",
  "bin": {
    "framework-sdd": "./bin/framework-sdd.mjs",
    "sdd": "./bin/framework-sdd.mjs",
    "sdd-agent": "./bin/sdd-agent.mjs"
  },
  "files": [
    "bin/framework-sdd.mjs",
    "bin/sdd-agent.mjs",
    "scripts/install-sdd-agent.mjs",
    "scripts/**/*.mjs",
    "scripts/**/*.sh",
    "scripts/fixtures/**",
    "openspec/tools-manifest.yaml",
    "openspec/gd-full-pipeline.yaml",
    "openspec/templates/**",
    "packages/sdd-agent-orchestrator/package.json",
    "packages/sdd-agent-orchestrator/package-lock.json",
    "packages/sdd-agent-orchestrator/src/**",
    "packages/sdd-agent-orchestrator/design/**",
    "packages/sdd-agent-orchestrator/README.md",
    "packages/sdd-agent-orchestrator/.env.example",
    ".claude/commands/gd/*.md",
    "docs/orquestador-agente-sdd.md",
    "docs/orquestador-produccion.md",
    "docs/openspec-proyectos.md",
    "openspec/projects/README.md"
  ],
  "scripts": {
    "spec:validate": "node scripts/validate-spec.mjs",
    "spec:validate-react": "node scripts/validate-react-schemas.mjs",
    "spec:verify": "node scripts/verify-change.mjs",
    "spec:implements": "node scripts/check-spec-implements.mjs",
    "test:implements-e2e": "node scripts/e2e-spec-implements.mjs",
    "test:extract-json-e2e": "node scripts/e2e-extract-json.mjs",
    "test:path-sandbox-e2e": "node scripts/e2e-path-sandbox.mjs",
    "spec:extract-json": "node scripts/extract-json-block.mjs",
    "framework:test": "npm run framework:ci && npm run test:implements-e2e && npm run test:extract-json-e2e && npm run test:path-sandbox-e2e && npm run orchestrator:test && npm run orchestrator:pipeline",
    "agent:install": "node scripts/install-sdd-agent.mjs",
    "agent:install:production": "node scripts/install-sdd-agent.mjs --production",
    "vscode:install-commands": "node scripts/install-vscode-gd-prompts.mjs && npm run agent:install", 
    "orchestrator:test": "npm ci --prefix packages/sdd-agent-orchestrator && npm test --prefix packages/sdd-agent-orchestrator",
    "orchestrator:pipeline": "npm run graph:pipeline --prefix packages/sdd-agent-orchestrator",
    "orchestrator:llm": "npm run graph:llm --prefix packages/sdd-agent-orchestrator",
    "orchestrator:gd-cycle": "npm run graph:gd-cycle --prefix packages/sdd-agent-orchestrator",
    "orchestrator:gd-catalog": "npm run graph:gd-catalog --prefix packages/sdd-agent-orchestrator",
    "orchestrator:gd-phase": "npm run graph:gd-phase --prefix packages/sdd-agent-orchestrator",
    "orchestrator:gd-mega-flow": "npm run graph:gd-mega-flow --prefix packages/sdd-agent-orchestrator",
    "orchestrator:audit-inventario": "npm run graph:audit-inventario --prefix packages/sdd-agent-orchestrator",
    "framework:platform-smoke": "npm run framework:test && npm run react:smoke",
    "framework:ci": "npm run spec:validate && npm run spec:validate-react && npm run spec:implements",
    "issue:smoke": "node scripts/test-github-issues-remediation.mjs",
    "issue:config-smoke": "node scripts/test-github-issues-config.mjs",
    "issue:evidence-smoke": "node scripts/test-github-issues-evidence.mjs",
    "issue:retry-smoke": "node scripts/test-github-retry-policy.mjs",
    "issue:local-smoke": "node scripts/test-github-local-fallback.mjs",
    "issue:dry-run": "node bin/sdd-issue-runner.cjs",
    "issue:doctor": "node bin/gd-github-doctor.cjs",
    "deploy:lambda:zip": "node scripts/package-lambda-zip.mjs",
    "token:benchmark": "node scripts/token-benchmark.mjs",
    "token:check": "node scripts/token-budget-check.mjs --strict",
    "prompt:compress": "node scripts/prompt-compress.mjs",
    "session:prune": "node scripts/session-prune.mjs",
    "react:run": "node scripts/react-runner.mjs",
    "react:list-tools": "node scripts/react-runner.mjs --list-tools",
    "react:smoke": "node scripts/react-runner.mjs --plan scripts/fixtures/react-plan-smoke.json",
    "rag:db:up": "docker compose -f rag/docker-compose.postgres.yml up -d",
    "rag:db:down": "docker compose -f rag/docker-compose.postgres.yml down",
    "rag:db:down:volume": "docker compose -f rag/docker-compose.postgres.yml down -v",
    "rag:db:logs": "docker compose -f rag/docker-compose.postgres.yml logs -f rag-postgres",
    "rag:migrate": "cd rag && npm install && node scripts/run-migration.mjs",
    "rag:index": "cd rag && node scripts/index.mjs",
    "rag:query": "cd rag && node scripts/query.mjs",
    "rag:test": "cd rag && npm install && node scripts/test-functional.mjs",
    "memory:daemons:start": "bash scripts/start-memory-daemons.sh",
    "memory:daemons:stop": "bash scripts/stop-memory-daemons.sh",
    "memory:daemons:status": "bash scripts/status-memory-daemons.sh",
    "pack:check": "npm pack --dry-run 2>&1",
    "task-dev:status": "node scripts/update-development-task-status.mjs",
    "task-dev:sync": "node scripts/update-development-task-status.mjs --sync",
    "task-dev:watch": "node scripts/watch-development-tasks.mjs",
    "task-dev:autonomous": "node scripts/run-autonomous-dev-queue.mjs",
    "task-dev:notify": "node scripts/notify-task-email.mjs",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js test-certification/certification.test.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "form-data": "^4.0.5",
    "js-yaml": "^4.1.1",
    "nodemailer": "^8.0.5",
    "octokit": "^5.0.5",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1029.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "pg": "^8.20.0"
  },
  "jest": {
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js",
      "**/test-certification/*.mjs"
    ]
  }
}

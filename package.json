{
  "name": "framework-sdd",
  "version": "2.0.1",
  "private": true,
  "description": "Specification-Driven Development — validación OpenSpec y artefactos de verificación para agentes",
  "type": "module",
  "scripts": {
    "spec:validate": "node scripts/validate-spec.mjs",
    "spec:validate-react": "node scripts/validate-react-schemas.mjs",
    "spec:verify": "node scripts/verify-change.mjs",
    "framework:ci": "npm run spec:validate && npm run spec:validate-react",
    "rag:db:up": "docker compose -f rag/docker-compose.postgres.yml up -d",
    "rag:db:down": "docker compose -f rag/docker-compose.postgres.yml down",
    "rag:db:down:volume": "docker compose -f rag/docker-compose.postgres.yml down -v",
    "rag:db:logs": "docker compose -f rag/docker-compose.postgres.yml logs -f rag-postgres",
    "rag:migrate": "cd rag && npm install && node scripts/run-migration.mjs",
    "rag:index": "cd rag && node scripts/index.mjs",
    "rag:query": "cd rag && node scripts/query.mjs",
    "rag:test": "cd rag && npm install && node scripts/test-functional.mjs",
    "memory:daemons:start": "bash scripts/start-memory-daemons.sh",
    "memory:daemons:stop": "bash scripts/stop-memory-daemons.sh",
    "memory:daemons:status": "bash scripts/status-memory-daemons.sh"
  },
  "devDependencies": {
    "ajv": "^8.17.1"
  },
  "engines": {
    "node": ">=20"
  }
}
